<div class="min-vh-100 d-flex align-items-center justify-content-center py-5" style="background:var(--meen-haze);">
  <div class="card border-0 w-100" style="max-width:420px; border-radius:var(--radius-lg); box-shadow:var(--shadow-md);">
    <div class="card-body p-5">
      <div class="text-center mb-4">
        <h1 class="h4 fw-bold mb-0" style="color:var(--meen-periwinkle);">Reset your password</h1>
        <p class="text-muted mb-0" style="font-size:var(--fs-small);">We'll email you a reset link</p>
      </div>

      <%= render "devise/shared/error_messages" %>

      <%= form_with url: password_path(resource_name), model: resource do |f| %>
        <input type="hidden" name="_method" value="post">
        <div class="mb-4">
          <%= f.label :email, class: "form-label fw-medium" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
        </div>
        <%= f.submit "Send reset instructions", class: "btn w-100 text-white fw-semibold py-2",
              style: "background:var(--meen-lavender); border-radius:var(--radius-pill);" %>
      <% end %>

      <hr class="my-4">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
