<div class="min-vh-100 d-flex align-items-center justify-content-center py-5" style="background:var(--meen-haze);">
  <div class="card border-0 w-100" style="max-width:420px; border-radius:var(--radius-lg); box-shadow:var(--shadow-md);">
    <div class="card-body p-5">
      <div class="text-center mb-4">
        <%= image_tag "Meen_logo_2.png", alt: "Meen", height: 72, class: "mb-2", style: "object-fit:contain;" %>
        <div class="mb-2" style="font-family:var(--font-display); font-weight:600; font-size:1.6rem; color:var(--meen-lavender);">meen</div>
        <h1 class="h5 fw-bold mb-0">Create your account</h1>
        <p class="text-muted mb-0" style="font-size:var(--fs-small);">Start your language journey</p>
      </div>

      <%= render "devise/shared/error_messages" %>

      <%= form_with url: registration_path(resource_name), model: resource do |f| %>
        <div class="mb-3">
          <%= f.label :email, class: "form-label fw-medium" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "you@example.com" %>
        </div>
        <div class="mb-3">
          <%= f.label :password, class: "form-label fw-medium" %>
          <% if @minimum_password_length %>
            <span class="text-muted ms-1" style="font-size:var(--fs-micro);">(<%= @minimum_password_length %> chars min)</span>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
        </div>
        <div class="mb-4">
          <%= f.label :password_confirmation, class: "form-label fw-medium" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>
        <%= f.submit "Create account", class: "btn w-100 text-white fw-semibold py-2",
              style: "background:var(--meen-lavender); border-radius:var(--radius-pill);" %>
      <% end %>

      <hr class="my-4">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
