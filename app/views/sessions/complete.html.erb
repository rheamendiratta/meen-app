<% content_for :title, "Session Complete — Meen" %>

<div class="container py-5 text-center" style="max-width:550px;">

  <div style="font-size:4rem; line-height:1;" class="mb-3">🎉</div>

  <h1 class="h3 fw-bold mb-2" style="color:var(--meen-periwinkle);">Session complete!</h1>
  <p class="text-muted mb-5">You're done for today. Greta is proud of you.</p>

  <div class="row g-3 mb-5">
    <div class="col-6">
      <div class="card border-0 p-4 text-center"
           style="border-radius:var(--radius-lg); box-shadow:var(--shadow-sm); background:var(--meen-white);">
        <div style="font-size:var(--fs-display); font-weight:700; color:var(--meen-periwinkle); line-height:1;">
          <%= @today.new_words_introduced %>
        </div>
        <div class="text-muted mt-1" style="font-size:var(--fs-small);">new words</div>
      </div>
    </div>
    <div class="col-6">
      <div class="card border-0 p-4 text-center"
           style="border-radius:var(--radius-lg); box-shadow:var(--shadow-sm); background:var(--meen-white);">
        <div style="font-size:var(--fs-display); font-weight:700; color:var(--meen-teal); line-height:1;">
          <%= @today.cards_reviewed %>
        </div>
        <div class="text-muted mt-1" style="font-size:var(--fs-small);">cards reviewed</div>
      </div>
    </div>
    <div class="col-12">
      <div class="card border-0 p-4 text-center"
           style="border-radius:var(--radius-lg); box-shadow:var(--shadow-sm); background:var(--meen-white);">
        <div style="font-size:var(--fs-display); font-weight:700; color:var(--meen-lavender); line-height:1;">
          <%= @language_streak %> 🔥
        </div>
        <div class="text-muted mt-1" style="font-size:var(--fs-small);">day streak</div>
      </div>
    </div>
  </div>

  <%= link_to "Back to dashboard →", dashboard_path,
        class: "btn text-white fw-semibold px-5 py-2",
        style: "background:var(--meen-lavender); border-radius:var(--radius-pill);" %>

</div>
