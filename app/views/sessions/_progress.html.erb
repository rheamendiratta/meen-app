<% steps = [
  { label: "Words",      icon: "📖" },
  { label: "Flashcards", icon: "🃏" },
  { label: "Speaking",   icon: "💬" },
  { label: "Listening",  icon: "🎧" },
  { label: "Reading",    icon: "📄" }
] %>

<div class="d-flex align-items-center justify-content-center gap-1 flex-wrap" style="font-size:var(--fs-small);">
  <% steps.each_with_index do |s, i| %>
    <% num = i + 1 %>
    <% is_current = num == step %>
    <% is_done = num < step %>
    <div class="d-flex align-items-center gap-1">
      <span class="d-flex align-items-center justify-content-center rounded-circle"
            style="width:28px; height:28px; font-size:0.75rem;
                   background:<%= is_done ? 'var(--meen-success)' : is_current ? 'var(--meen-lavender)' : 'var(--meen-border)' %>;
                   color:<%= (is_done || is_current) ? 'white' : 'var(--meen-ink-muted)' %>;">
        <%= is_done ? "✓" : num %>
      </span>
      <span style="color:<%= is_current ? 'var(--meen-ink)' : 'var(--meen-ink-muted)' %>; font-weight:<%= is_current ? '600' : '400' %>;">
        <%= s[:label] %>
      </span>
    </div>
    <% if i < steps.size - 1 %>
      <span style="color:var(--meen-border);">—</span>
    <% end %>
  <% end %>
</div>
