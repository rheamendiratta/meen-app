<% content_for :title, "Settings — Meen" %>

<div class="container py-5" style="max-width: 540px;">
  <h1 class="mb-4" style="font-size: var(--fs-h1);">Settings</h1>

  <%# Account %>
  <div class="card mb-3" style="border-radius: var(--radius-md);">
    <div class="card-body px-4 py-3">
      <p class="text-muted mb-1" style="font-size: var(--fs-micro); text-transform: uppercase; letter-spacing: 0.06em;">Account</p>
      <p class="mb-2" style="font-size: var(--fs-small);">
        <%= current_user.email %>
      </p>
      <%= link_to "Edit email & password",
            edit_user_registration_path,
            style: "font-size: var(--fs-small); color: var(--meen-lavender); text-decoration: none;" %>
    </div>
  </div>

  <%# Language %>
  <div class="card mb-3" style="border-radius: var(--radius-md);">
    <div class="card-body px-4 py-3">
      <p class="text-muted mb-1" style="font-size: var(--fs-micro); text-transform: uppercase; letter-spacing: 0.06em;">Language</p>
      <% if current_user.active_language.present? %>
        <p class="mb-0" style="font-size: var(--fs-small);">
          Currently learning <strong><%= current_user.active_language.name %></strong>
          &nbsp;·&nbsp; streak 🔥 <%= current_user.current_streak %>
        </p>
      <% end %>
    </div>
  </div>

  <%# Sign out %>
  <div class="card mb-3" style="border-radius: var(--radius-md);">
    <div class="card-body px-4 py-3">
      <%= link_to "Sign out",
            destroy_user_session_path,
            style: "font-size: var(--fs-small); color: var(--meen-danger); text-decoration: none;" %>
    </div>
  </div>
</div>
