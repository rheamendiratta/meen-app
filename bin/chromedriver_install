#!/usr/bin/env bash
# Script to install chrome-headless-shell + matching chromedriver at the system
# level for Linux. Called from .devcontainer/devcontainer.json's postCreateCommand.
#
# Why chrome-headless-shell instead of full Chrome:
#   Full Chrome needs GTK/X11 libs (libgtk-3-0, libatk-bridge2.0-0, etc.) whose
#   required versions live in focal-security, which codespaces can't reliably
#   reach. That made the previous --install-deps approach flaky. The headless
#   shell is a slimmer headless-only Chrome variant with far fewer system-lib
#   deps, so we can skip apt-get entirely. Our Capybara config already runs
#   --headless, so we lose nothing.

set -euo pipefail

CHROME_VERSION=148.0.7778.97
CHROME_HEADLESS_PATH="/usr/local/chrome-headless-shell"
CHROMEDRIVER_PATH="/usr/local/chromedriver"
sudo mkdir -p "$CHROME_HEADLESS_PATH" "$CHROMEDRIVER_PATH"

sudo npx -y @puppeteer/browsers install chrome-headless-shell@${CHROME_VERSION} --path="$CHROME_HEADLESS_PATH"
sudo npx -y @puppeteer/browsers install chromedriver@${CHROME_VERSION} --path="$CHROMEDRIVER_PATH"

sudo ln -sf ${CHROME_HEADLESS_PATH}/chrome-headless-shell/linux-${CHROME_VERSION}/chrome-headless-shell-linux64/chrome-headless-shell /usr/local/bin/chrome-headless-shell
sudo ln -sf ${CHROMEDRIVER_PATH}/chromedriver/linux-${CHROME_VERSION}/chromedriver-linux64/chromedriver /usr/local/bin/chromedriver
